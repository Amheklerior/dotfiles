# ------------------------------------------------------------------------------
# ZOXIDE SETUP
# ------------------------------------------------------------------------------
# setup zoxide as a modern and faster `cd` command replacement. zoxide tracks
# your most visited directories, and allows you to jump to them with fuzzy
# searching, avoiding the need to type long paths.
#
# see: https://github.com/ajeetdsouza/zoxide
# ------------------------------------------------------------------------------

eval "$(zoxide init zsh --cmd cd)"