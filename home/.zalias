# ------------------------------------------------------------------------------
# CORE SHELL ALIASES
# ------------------------------------------------------------------------------
# These are my core shell aliases. They include:
#   - drop-in replacements for common commands using modern alternatives,
#   - shortcuts for rapid file system navigation,
#   - quick-view options for listing directories content,
#   - structured tree-like views for the file system,
#   - general quality of life shortcuts (quit, view PATH, ...)
# ------------------------------------------------------------------------------

# use ripgrep as a drop-in replacement for `grep`
alias grep="rg"
alias rg="rg --colors=match:fg:green"

# exit shortcuts
alias q="exit"
alias quit="exit"

# quick navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias -- -="cd -"
alias dl="cd ~/Downloads"
alias desk="cd ~/Desktop"
alias personal='cd $PERSONAL'
alias work='cd $WORK'
alias dot='cd $DOTFILES_REPO'
alias sys='cd $SYSENV_REPO'

# list views
alias ls="eza --all --oneline --classify --group-directories-first --icons"
alias ll="eza --all --long --classify --header --group --group-directories-first --icons"
alias ld="ls --only-dirs"
alias lf="ls --only-files"
alias lld="ll --only-dirs"
alias llf="ll --only-files"

# tree views
alias tree="eza --tree --all --classify --icons --group-directories-first"
alias t="tree --git-ignore --ignore-glob .git"
alias t2="t -L2"
alias t4="t -L4"

# list binary and function paths in a more readable format
alias bpath='echo $PATH | sed "s/:/\n/g"'
alias fnpath='echo $FPATH | sed "s/:/\n/g"'

# ------------------------------------------------------------------------------
# DOTFILES MANAGEMENT ALIASES
# ------------------------------------------------------------------------------
# Aliases to quickly edit, relink, reload my dotfiles.
# ------------------------------------------------------------------------------

# (e)dit (dot)files
alias edot='$EDITOR $DOTFILES_REPO'

# (l)ink (dot)files
alias ldot='stow -R -d $DOTFILES_REPO -t $HOME home'

# (s)ource (dot)files
alias sdot='source $HOME/.zshenv; source $HOME/.zshrc'

# ------------------------------------------------------------------------------
# DEVELOPMENT ALIASES
# ------------------------------------------------------------------------------
# Shortcuts for editors, git, node package managers, Docker, log inspection
# and more...
# ------------------------------------------------------------------------------

# editor shortcuts
alias e='$EDITOR'
alias v="nvim"
alias vim="nvim"

# main git commands
alias g="git"
alias gf="git fetch --all"
alias gco="git checkout"
alias gs="git status --short"
alias ga="git add"
alias gaa="git add --all"
alias gai="git add -p"
alias gb="git branch"
alias gw="git worktree"
alias gc="git commit"
alias gp="git push"
alias gl="git log --oneline --graph -15"
alias gla="git log --oneline --graph --all -25"

# node package managers
alias y='yarn'
alias p='pnpm'

# docker and docker compose shortcuts
alias doco="docker compose"

# tail log files with syntax highlighting
watch() { tail -f "$1" | bat --paging=never -l log; }

# ------------------------------------------------------------------------------
# UTILITY ALIASES
# ------------------------------------------------------------------------------

# copy the current working directory to the clipboard
alias cpwd="pwd | tr -d '\n' | pbcopy"

# Recursively remove Apple meta files
alias rmds="find . -type f -name '*.DS_Store' -ls -delete"
alias rmad="find . -type d -name '.AppleD*' -ls -exec /bin/rm -r {} \;"
